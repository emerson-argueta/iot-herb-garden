# Herb Garden Edge — default sdkconfig overrides.
# User-specific values (SSID, password, broker IP) live in sdkconfig.local
# which is git-ignored.  Override them there, not here.

# Baseline clock speed
CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y

# FreeRTOS tick at 1 kHz for pdMS_TO_TICKS accuracy
CONFIG_FREERTOS_HZ=1000

# Enough stack for MQTT + JSON
CONFIG_MQTT_BUFFER_SIZE=1024

# Log level: INFO for production, DEBUG for development
CONFIG_LOG_DEFAULT_LEVEL_INFO=y

# Enable NVS encryption if flash encryption is used (off by default)
CONFIG_NVS_ENCRYPTION=n
